<!DOCTYPE html>
<html lang="en">
    <head>
        <%- include("../partials/head") %>
        <link rel="stylesheet" href="/new-page.css" />
        <script src="https://kit.fontawesome.com/e35a6b4d49.js" crossorigin="anonymous"></script>
    </head>
    <body>
        <header class="header-column">
            <%-include("../partials/backBtn") %>
            <h1 class="header-h1">Create New Post</h1>
        </header>
        <main>
            <div class="form-wrapper">
                <form method="POST" action="/new">
                    <div class="input-wrapper">
                        <label for="name">Name</label>
                        <input
                            id="name"
                            name="user"
                            placeholder="Enter your name..."
                            autocomplete="off"
                            required
                            maxlength="32"
                        />
                    </div>
                    <div class="input-wrapper">
                        <label for="message">Your Message</label>
                        <textarea
                            id="message"
                            name="message"
                            rows="15"
                            placeholder="Share your message with everybody..."
                            autocomplete="off"
                            required
                            minlength="2"
                            maxlength="200"
                        ></textarea>
                    </div>
                    <%-include("../partials/errors") %>
                    <button class="btn submit-btn">Post Message</button>
                </form>
            </div>
        </main>
    </body>
</html>
